{
  "name": "nuxt-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:test": "MODE=development nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky && pnpm echo:husky",
    "echo:husky": "echo 'npx --no-install nano-staged' > .husky/pre-commit && echo 'npx --no-install commitlint --edit \"$1\"' > .husky/commit-msg",
    "commit": "git-cz",
    "lint": "oxlint --deny-warnings && eslint .",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "deploy:test": "pnpm build:test && pm2 start ./pm2.config.json --env test",
    "deploy": "pnpm build && pm2 start ./pm2.config.json"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "nano-staged"
    }
  },
  "nano-staged": {
    "**/*.{ts,vue}": [
      "oxlint --deny-warnings --fix",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/devtools": "4.0.0-alpha.4",
    "@nuxt/eslint": "^1.15.2",
    "@unocss/nuxt": "66.6.8",
    "@unocss/preset-rem-to-px": "66.6.8",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "nuxt": "^4.4.2",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.2",
    "typescript": "6.0.2",
    "unocss": "66.6.8",
    "vite-plugin-remove-console": "^2.2.0"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "nuxt-custom-fetch": "^4.4.0",
    "pinia": "^3.0.4"
  }
}
